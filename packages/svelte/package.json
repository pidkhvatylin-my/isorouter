{
  "name": "@isorouter/svelte",
  "version": "1.0.0",
  "description": "Svelte 5 adapter for @isorouter/core.",
  "license": "MIT",
  "author": "Mykhailo Pidkhvatylin <michel.podkhvatilin@gmail.com>",
  "homepage": "https://github.com/pidkhvatylin-my/isorouter/tree/master/packages/svelte#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pidkhvatylin-my/isorouter.git",
    "directory": "packages/svelte"
  },
  "bugs": "https://github.com/pidkhvatylin-my/isorouter/issues",
  "keywords": [
    "router",
    "routing",
    "spa",
    "navigation-api",
    "svelte",
    "typescript"
  ],
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "LICENSE"
  ],
  "svelte": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "svelte-package -i src -o dist",
    "check": "svelte-check --tsconfig ./tsconfig.json && publint && eslint . && prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:all": "npm run test && npm run test:e2e"
  },
  "peerDependencies": {
    "svelte": "^5.7.0"
  },
  "dependencies": {
    "@isorouter/core": "^1.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@isorouter/test-utils": "^1.0.0",
    "@playwright/test": "^1.60.0",
    "@sveltejs/package": "^2.3.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.19.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "prettier-plugin-svelte": "^4.1.0",
    "publint": "^0.3.0",
    "svelte": "^5.7.0",
    "svelte-check": "^4.0.0",
    "svelte-eslint-parser": "^1.8.0",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  }
}
