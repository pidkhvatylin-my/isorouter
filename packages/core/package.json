{
  "name": "@isorouter/core",
  "version": "1.2.1",
  "description": "Framework-agnostic router built on the Navigation API.",
  "license": "MIT",
  "author": "Mykhailo Pidkhvatylin <michel.podkhvatilin@gmail.com>",
  "homepage": "https://github.com/pidkhvatylin-my/isorouter/tree/master/packages/core#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pidkhvatylin-my/isorouter.git",
    "directory": "packages/core"
  },
  "bugs": "https://github.com/pidkhvatylin-my/isorouter/issues",
  "keywords": [
    "router",
    "routing",
    "spa",
    "navigation-api",
    "framework-agnostic",
    "typescript"
  ],
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && rolldown -c && tsc -p tsconfig.build.json",
    "check": "tsc --noEmit && publint && eslint . && prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:native": "playwright test --project=chromium",
    "test:e2e:polyfill": "playwright test --project=chromium-polyfill",
    "test:all": "npm run test && npm run test:e2e"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@isorouter/test-utils": "^1.0.0",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.0.0",
    "@virtualstate/navigation": "1.0.1-alpha.212",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "fast-check": "^4.8.0",
    "prettier": "^3.8.4",
    "publint": "^0.3.0",
    "rolldown": "^1.1.3",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.0"
  }
}
